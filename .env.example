# Optional: MCP unique-install telemetry (Supabase)
# Copy to .env and set these to enable tracking. Leave unset to disable.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# Opt-out: set to off to disable telemetry even when Supabase is configured
# VIBELINT_TELEMETRY=off
